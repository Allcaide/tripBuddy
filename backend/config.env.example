NODE_ENV=development
PORT=3000

# MongoDB — substituir <PASSWORD> pela password real
DATABASE=mongodb+srv://<USERNAME>:<PASSWORD>@cluster0.xxxxx.mongodb.net/?retryWrites=true&w=majority&appName=Cluster0
DATABASE_PASSWORD=<YOUR_DB_PASSWORD>

# JWT
JWT_SECRET=<a-random-secret-string-min-32-chars>
JWT_EXPIRES_IN=90d
JWT_COOKIE_EXPIRES_IN=90

# Mailtrap (desenvolvimento)
EMAIL_USERNAME=<mailtrap_username>
EMAIL_PASSWORD=<mailtrap_password>
EMAIL_HOST=sandbox.smtp.mailtrap.io
EMAIL_PORT=2525

# SendGrid (produção)
SENDGRID_USERNAME=apikey
SENDGRID_PASSWORD=<SG.your_sendgrid_api_key>

# Stripe
STRIPE_SECRET_KEY=<sk_test_your_stripe_secret_key>
STRIPE_WEBHOOK_SECRET=<whsec_your_webhook_secret>

# Frontend URL (para redirects do Stripe, emails, etc.)
FRONTEND_URL=http://localhost:5173
